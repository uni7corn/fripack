{
    "base": {
        "version": "1.0.0",
        "fridaVersion": "17.5.1",
        "mode": "embedjs",
        "entry": "main_compiled.js",
        "xz": true,
        "outputDir": "./fripack",
        "targetBaseName": "fripack"
    },
    "xp": {
        "inherit": "base",
        "type": "xposed",
        "platform": "android-arm64",
        "xposed": {
            "packageName": "com.fripack.examplexposedmodule",
            "name": "Fripack Xposed Module Example",
            "scope": "tv.danmaku.bili"
        },
        "sign": {
            "keystore": "C:\\Users\\MicroBlock\\.android\\debug.keystore",
            "keystorePass": "android",
            "keystoreAlias": "androiddebugkey"
        },
        // "afterBuild": "adb install fripack/fripack-android-arm64.apk",
        // "overridePrebuildFile": "E:\\fripack\\build\\fripack-inject\\build\\android\\arm64-v8a\\debug\\libfripack-inject.so",
    },
    "xp-arm32": {
        "inherit": "xp",
        "platform": "android-arm32",
        "xposed": {
            "packageName": "com.fripack.examplexposedmodule.arm32",
            "name": "Fripack Xposed Module Example arm32",
            "scope": "tv.danmaku.bili"
        },
        "afterBuild": "adb install fripack/fripack-android-arm.apk",
    },
    "xp-x86": {
        "inherit": "xp",
        "platform": "android-x86",
    },
    "xp-x86_64": {
        "inherit": "xp",
        "platform": "android-x86_64",
    },
    "android_so": {
        "inherit": "base",
        "type": "shared",
        "platform": "android-arm64",
    },
    "linux_so": {
        "inherit": "base",
        "type": "shared",
        "platform": "linux-x64",
    },
    "windows_dll": {
        "inherit": "base",
        "type": "shared",
        "platform": "windows-x64",
    },
    "zygisk": {
        "inherit": "base",
        "type": "zygisk",
        "platform": "android-arm64",
        "zygisk": {
            "id": "com.fripack.examplezygiskmodule",
            "name": "Fripack Zygisk Module Example",
            "scope": "com.yunzhi.tiyu;com.hypergryph.skland;com.hypergryph.arknights;com.qihoo.zhinao;tv.danmaku.bili",
        },
    },
    "xp-watch": {
        "inherit": "xp",
        "mode": "watchpath",
        "watchPath": "./scripts",
        "pushPath": "/data/local/tmp/",
        "entry": "main.js"
    },
    "inject-apk": {
        "inherit": "base",
        "type": "inject-apk",
        "platform": "android-arm64",
        "fridaVersion": "17.5.1",
        "entry": "main.js",
        "injectApk": {
            "sourceApkPath": "C:\\Users\\MicroBlock\\Downloads\\BlockGram Desktop\\Bili-v8.65.0-x1.26.6@bb_show.apk",
            "injectMode": "NativeAddNeeded",
        },
        "sign": {
            "keystore": "C:\\Users\\MicroBlock\\.android\\debug.keystore",
            "keystorePass": "android",
            "keystoreAlias": "androiddebugkey"
        }
    },
    "inject-apk-2": {
        "inherit": "base",
        "type": "inject-apk",
        "platform": "android-arm64",
        "fridaVersion": "17.5.1",
        "entry": "main.js",
        "injectApk": {
            "sourceApkPackageName": "com.catchingnow.icebox",
            "injectMode": "NativeAddNeeded",
        },
        "sign": {
            "keystore": "/Users/microblock/.android/debug.keystore",
            "keystorePass": "android",
            "keystoreAlias": "androiddebugkey"
        }
    }
}